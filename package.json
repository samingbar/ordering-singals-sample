{
  "name": "temporal-typescript-template",
  "version": "0.1.0",
  "private": true,
  "description": "Temporal TypeScript SDK sample template",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "worker:http": "tsx src/workflows/http/worker.ts",
    "workflow:http": "tsx src/workflows/http/run.ts",
    "worker:crawler": "tsx src/workflows/crawler/worker.ts",
    "workflow:crawler": "tsx src/workflows/crawler/run.ts",
    "worker:load-generator": "tsx src/workflows/load_generator/worker.ts",
    "workflow:load-generator": "tsx src/workflows/load_generator/run.ts",
    "worker:purchase-order": "tsx src/workflows/purchase_order/worker.ts",
    "server:api": "tsx src/apps/api/server.ts",
    "server:vendor-sim": "tsx src/apps/vendor_sim/server.ts",
    "demo": "concurrently -k \"npm:worker:purchase-order\" \"npm:server:api\" \"npm:server:vendor-sim\""
  },
  "dependencies": {
    "@temporalio/client": "^1.0.0",
    "@temporalio/testing": "^1.0.0",
    "@temporalio/worker": "^1.0.0",
    "@temporalio/workflow": "^1.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
