{
  "image": "ghcr.io/mrsimonemms/devcontainers/base",
  "name": "Temporal TypeScript Template",
  "features": {
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers-extra/features/temporal-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": ["biomejs.biome", "ms-vscode.vscode-typescript-next", "vitest.explorer"]
    }
  },
  "containerEnv": {
    "TEMPORAL_ADDRESS": "localhost:7233",
    "PRE_COMMIT_HOME": "/home/vscode/.cache/pre-commit"
  },
  "forwardPorts": [8080, 8233],
  "initializeCommand": {
    "init-pre-commit-cache": "mkdir -p ${localEnv:HOME}${localEnv:USERPROFILE}/.cache"
  },
  "postCreateCommand": {
    "git-safe-directory": "git config --global --add safe.directory ${containerWorkspaceFolder}",
    "pre-commit": "pre-commit install --install-hooks -t pre-commit -t commit-msg --allow-missing-config || true"
  },
  "postStartCommand": {
    "temporal-server": "nohup bash -c 'temporal server start-dev &'",
    "npm-install": "npm install"
  }
}
